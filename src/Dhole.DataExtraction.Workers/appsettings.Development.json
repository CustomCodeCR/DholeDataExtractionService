{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "EmailIngestion": {
    "StoragePath": "./storage/data-extraction",
    "MaxMessagesPerSync": 25,
    "MaxExtractionJobsPerRun": 10
  },
  "Storage": {
    "ExtractionFiles": {
      "RootPath": "./storage/data-extraction/pricing-imports"
    }
  },
  "Pricing": {
    "ImportFromExtractionUrl": "http://localhost:5204/api/pricing/rate-import-batches/from-extraction",
    "TimeoutSeconds": 60,
    "ApiKeyHeader": "X-Api-Key"
  },
  "Grpc": {
    "Clients": {
      "Config": {
        "Address": "http://localhost:5302"
      },
      "AI": {
        "Address": "http://localhost:5307"
      }
    }
  },
  "Mongo": {
    "ConnectionString": "mongodb://localhost:27017",
    "DatabaseName": "dhole_data_extraction",
    "EnableHealthCheck": false
  },
  "AI": {
    "EmailFallback": {
      "Enabled": true,
      "ProfileKey": "pricing-email-analysis",
      "TimeoutSeconds": 300,
      "MaximumContentCharacters": 50000,
      "MaximumEmailContextCharacters": 8000
    }
  }
}
