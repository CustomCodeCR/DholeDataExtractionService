{
  "ConnectionStrings": {
    "Postgres": "Host=localhost;Port=5432;Database=dhole_data_extraction;Username=postgres;Password=turbodiesel"
  },
  "Postgres": {
    "ConnectionString": "Host=localhost;Port=5432;Database=dhole_data_extraction;Username=postgres;Password=turbodiesel",
    "CommandTimeoutSeconds": 30,
    "EnableHealthCheck": true
  },
  "Redis": {
    "ConnectionString": "localhost:6379",
    "InstanceName": "dhole_data_extraction:",
    "DefaultExpirationMinutes": 30,
    "EnableHealthCheck": true,
    "Streams": {
      "Enabled": true,
      "DefaultStreamName": "dhole.data-extraction.events",
      "SourceService": "DholeDataExtractionService",
      "Destinations": {
        "audit.event.registered": "dhole.audit.events",
        "data-extraction.execution.completed": "dhole.data-extraction.events",
        "data-extraction.execution.failed": "dhole.data-extraction.events"
      },
      "Consumer": {
        "Enabled": true,
        "StreamName": "dhole.data-extraction.events",
        "ConsumerGroup": "dhole-data-extraction",
        "ConsumerName": "dhole-data-extraction-worker",
        "BatchSize": 50,
        "PollingIntervalSeconds": 5
      }
    }
  },
  "Messaging": {
    "Outbox": {
      "BatchSize": 50,
      "MaxRetryCount": 3,
      "PollingIntervalSeconds": 10,
      "BackgroundService": {
        "Enabled": true,
        "PollingIntervalSeconds": 10,
        "BatchSize": 50,
        "RunImmediately": true
      }
    },
    "Inbox": {
      "CleanupIntervalMinutes": 60,
      "RetentionDays": 7,
      "BatchSize": 100
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  }
