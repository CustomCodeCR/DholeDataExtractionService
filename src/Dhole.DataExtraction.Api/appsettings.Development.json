{
  "Auth": {
    "Jwt": {
      "RequireHttpsMetadata": false
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Http": {
    "Port": 5205
  },
  "Grpc": {
    "Server": {
      "Port": 5306,
      "MaxMessageSizeBytes": 67108864
    },
    "Clients": {
      "Config": {
        "Address": "http://localhost:5102"
      }
    }
  },
  "Storage": {
    "ExtractionFiles": {
      "RootPath": "./storage/data-extraction/pricing-imports"
    }
  },
  "EmailIngestion": {
    "StoragePath": "./storage/data-extraction",
    "MaxMessagesPerSync": 25,
    "MaxExtractionJobsPerRun": 10
  },
  "Pricing": {
    "ImportFromExtractionUrl": "http://localhost:5206/api/pricing/rate-import-batches/from-extraction",
    "TimeoutSeconds": 60,
    "ApiKeyHeader": "X-Api-Key"
  }
}
